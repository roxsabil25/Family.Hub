<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title><%= title %></title>

<!-- Tailwind -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- FontAwesome -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
.fade-up{
  animation: fadeUp .8s ease forwards;
}
@keyframes fadeUp{
  from{opacity:0; transform:translateY(40px);}
  to{opacity:1; transform:translateY(0);}
}
</style>

</head>

<body class="bg-gray-50 text-gray-800">

<!-- ================= NAVBAR ================= -->
<header class="font-sans w-full bg-white shadow-sm overflow-hidden">

  <div class="bg-gray-100 py-2 px-4 md:px-10 flex flex-col md:flex-row justify-between items-center text-[10px] md:text-xs text-gray-600 border-b gap-2">
    <div class="flex items-center gap-4">
        <span class="font-medium"><i class="fa-solid fa-phone mr-1"></i> +880 1976-055300</span>
        <span class="hidden sm:inline border-l border-gray-300 pl-4">Worldwide shipping available</span>
    </div>
    <div class="flex gap-4 md:gap-6">
      <span><i class="fa-solid fa-envelope mr-1"></i> <a href="mailto:heba@alhebaexport.com" class="hover:text-blue-600 transition">info@alhebaexport.com</a></span>
    </div>
  </div>

  <div class="bg-white py-3 md:py-5 px-4 md:px-10 flex flex-wrap items-center justify-between gap-4">
    
    <div class="flex items-center gap-3 shrink-0">
       <img class="w-[40px] md:w-[50px] rounded-md" src="/WhatsApp Image 2026-03-20 at 12.23.49 AM.jpeg" alt="Logo">
       <div class="text-blue-900 font-bold text-xs md:text-sm leading-tight">
          AL HEBA FOOD <br> EXPORT IMPORT L.L.C
       </div>
    </div>

    <div class="w-full lg:flex-1 lg:max-w-xl order-3 lg:order-2">
      <div class="relative group">
        <input type="text" placeholder="Search products..." 
               class="w-full border border-gray-200 rounded-full py-2 pl-4 pr-10 focus:outline-none focus:ring-1 focus:ring-green-600 text-sm transition-all bg-gray-50 focus:bg-white">
        <button class="absolute right-3 top-2 text-gray-400 group-focus-within:text-green-600">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
      </div>
    </div>

    <div class="flex items-center gap-4 md:gap-6 text-gray-700 order-2 lg:order-3">
      <a href="/profile" class="flex flex-col items-center hover:text-green-700 transition">
        <i class="fa-regular fa-circle-user text-xl md:text-2xl"></i>
        <span class="text-[10px] hidden md:block">
            <%= user ? user.name : 'Account' %>
        </span>
      </a>

      <a href="https://wa.me/+8801976055300" class="flex flex-col items-center hover:text-green-700 transition">
        <i class="fa-solid fa-headset text-xl md:text-2xl"></i>
        <span class="text-[10px] hidden md:block">Help</span>
      </a>

      <div class="flex flex-col items-center cursor-pointer hover:text-green-700 transition relative">
        <i class="fa-solid fa-cart-shopping text-xl md:text-2xl"></i>
        <span class="absolute -top-1 -right-2 bg-red-500 text-white text-[9px] font-bold rounded-full h-4 w-4 flex items-center justify-center">0</span>
        <span class="text-[10px] hidden md:block">Checkout</span>
      </div>
    </div>
  </div>

  <nav class="bg-green-700 text-white shadow-inner">
    <div class="px-4 md:px-10 flex items-center">
      <ul class="flex items-center gap-1 py-1 overflow-x-auto whitespace-nowrap no-scrollbar text-sm font-medium w-full">
        <a href="/"><li class="bg-white text-green-800 px-4 py-2 rounded-t-sm transition-all">Home</li></a>
        
        <a href="/about"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">About us</li></a>
        
        <a href="/products"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 flex items-center gap-1 transition-all">Products <i class="fa-solid fa-chevron-down text-[10px]"></i></li></a>

        <a href="/products"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 flex items-center gap-1 transition-all">Short Product  <i class="fa-solid fa-chevron-down text-[10px]"></i></li></a>

        <a href="/products"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 flex items-center gap-1 transition-all">Bulk Product  <i class="fa-solid fa-chevron-down text-[10px]"></i></li></a>

        <a href="#"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">Indentor</li></a>

        <a href="#"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">Partnership</li></a>

        <a href="#"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">e-Commerce</li></a>

        <a href="#"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">Certificate</li></a>

        <a href="#"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 transition-all">Blog</li></a>
        
        <a href="/sourcing"><li class="px-4 py-2 hover:bg-green-800 border-l border-green-600/30 flex items-center gap-1 transition-all">Sourcing Agent <i class="fa-solid fa-chevron-down text-[10px]"></i></li></a>

        <li class="bg-yellow-500 hover:bg-yellow-600 text-green-900 px-5 py-2 rounded-sm ml-auto cursor-pointer font-bold transition-all shadow-md">
            Contact
        </li>
      </ul>
    </div>
  </nav>

</header>

<style>
  /* Scrollbar hide korar jonno */
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  /* Active state effects */
  nav li {
      transition: all 0.2s ease-in-out;
  }
</style>