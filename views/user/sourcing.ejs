<%- include('./partials/header', {title: 'Sourcing | Family Hub'}) %>


<section class="pt-24 pb-12 bg-green-50">
    <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-1/2 fade-up">
            <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 mb-6 leading-tight">
                Your Trusted <span class="text-green-600">Sourcing Partner</span>
            </h1>
            <p class="text-lg text-gray-600 mb-8">
                We bridge the gap between you and reliable suppliers. Our team ensures high-quality products at competitive prices, delivered straight to your doorstep. Let us simplify your business procurement.
            </p>
            <a href="#contact-form" class="bg-green-600 text-white px-8 py-3 rounded-full font-bold hover:bg-green-700 transition shadow-lg">
                Get a Quote
            </a>
        </div>
        <div class="md:w-1/2">
            <img src="https://images.unsplash.com/photo-1578575437130-527eed3abbec?auto=format&fit=crop&q=80&w=800" 
                 alt="Sourcing" class="rounded-3xl shadow-2xl">
        </div>
    </div>
</section>

<section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center mb-16 tracking-wide">HOW WE WORK</h2>
        
        <div class="grid md:grid-cols-3 gap-12 relative">
            <div class="text-center relative z-10">
                <div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-xl">1</div>
                <h3 class="text-xl font-bold mb-3">Product Selection</h3>
                <p class="text-gray-500 italic">Send us your requirements and the list of products you need.</p>
            </div>
            
            <div class="text-center relative z-10">
                <div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-xl">2</div>
                <h3 class="text-xl font-bold mb-3">Supplier Verification</h3>
                <p class="text-gray-500 italic">We find and verify the best factories and trusted suppliers for you.</p>
            </div>

            <div class="text-center relative z-10">
                <div class="w-16 h-16 bg-green-600 text-white rounded-full flex items-center justify-center text-2xl font-bold mx-auto mb-6 shadow-xl">3</div>
                <h3 class="text-xl font-bold mb-3">Shipping & Delivery</h3>
                <p class="text-gray-500 italic">After strict quality control, we deliver the goods to your location.</p>
            </div>
        </div>
    </div>
</section>

<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-12">OUR CORE SERVICES</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <i class="fa-solid fa-magnifying-glass-chart text-3xl text-green-600 mb-4"></i>
                <h4 class="font-bold mb-2">Market Research</h4>
                <p class="text-sm text-gray-600">We analyze current market trends and pricing to get you the best deal.</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <i class="fa-solid fa-file-contract text-3xl text-green-600 mb-4"></i>
                <h4 class="font-bold mb-2">Quality Inspection</h4>
                <p class="text-sm text-gray-600">Strict quality checks are performed before any shipment leaves.</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <i class="fa-solid fa-comments-dollar text-3xl text-green-600 mb-4"></i>
                <h4 class="font-bold mb-2">Price Negotiation</h4>
                <p class="text-sm text-gray-600">We negotiate directly with suppliers to reduce your costs.</p>
            </div>
            <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 hover:shadow-md transition">
                <i class="fa-solid fa-warehouse text-3xl text-green-600 mb-4"></i>
                <h4 class="font-bold mb-2">Logistics Support</h4>
                <p class="text-sm text-gray-600">Complete warehousing and shipping management for your peace of mind.</p>
            </div>
        </div>
    </div>
</section>

<section id="contact-form" class="py-16 bg-white">
    <div class="max-w-3xl mx-auto px-4 bg-gray-50 p-10 rounded-3xl shadow-inner border border-gray-200">
        <h2 class="text-3xl font-bold text-center mb-4">Send Sourcing Request</h2>
        <p class="text-center text-gray-500 mb-10">Tell us what you need, and our experts will get back to you within 24 hours.</p>
        
        <form class="space-y-6">
            <div class="grid md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-semibold mb-2">Full Name</label>
                    <input type="text" placeholder="John Doe" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Phone Number</label>
                    <input type="tel" placeholder="+1 234 567 890" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-500">
                </div>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Product Details</label>
                <textarea rows="4" class="w-full px-4 py-3 rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-green-500" placeholder="Describe the products you are looking for..."></textarea>
            </div>
            <button type="submit" class="w-full bg-green-600 text-white font-bold py-4 rounded-xl hover:bg-green-700 transition">Submit Request</button>
        </form>
    </div>
</section>








<%- include('./partials/footer') %>