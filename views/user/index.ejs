    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      <% if (products.length > 0) { %>
        <% products.forEach((product) => { %>
          <a href="/products/details/<%= product._id %>" class="bg-white rounded-2xl overflow-hidden shadow hover:shadow-2xl transition hover:-translate-y-2 group">
            <div class="overflow-hidden h-60 md:h-72 lg:h-64">
              <img src="<%= product.productsImge %>" class="h-full w-full object-cover group-hover:scale-110 transition duration-500" alt="<%= product.productname %>">
            </div>
            <h3 class="text-center py-4 font-semibold text-gray-800">
