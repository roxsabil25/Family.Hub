<script>
    const images = [
        "/WhatsApp Image 2026-03-06 at 11.11.14 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.17 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.17 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.21 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.22 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.22 PM (2).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.22 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.23 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.23 PM (2).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.23 PM (3).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.23 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.24 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.24 PM (2).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.24 PM (3).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.24 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.25 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.25 PM (2).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.26 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.21 PM (1).jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.26 PM.jpeg",
        "/WhatsApp Image 2026-03-06 at 11.11.25 PM.jpeg",
        // ... এভাবে img20 পর্যন্ত এড করুন
    ];

    let currentIndex = 0;
    const imgElement = document.getElementById('slideshow-img');

    function changeImage() {
        // opacity কমিয়ে একটি fade effect আনা যায়
        imgElement.style.opacity = 0;

        setTimeout(() => {
            currentIndex = (currentIndex + 1) % images.length;
            imgElement.src = images[currentIndex];
            imgElement.style.opacity = 1;
        }, 500); // 0.5 সেকেন্ড সময় নেবে fade হতে
    }

    // প্রতি ৫ সেকেন্ড (৫০০০ মিলিসেকেন্ড) পর পর ফাংশনটি কল হবে
    setInterval(changeImage, 5000);
</script>


