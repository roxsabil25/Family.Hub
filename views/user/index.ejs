            </h3>
          </a>
        <% }) %>
      <% } else { %>
        <p class="text-center col-span-full text-gray-500">No products found.</p>
      <% } %>
    </div>

    <% if (totalPages > 1) { %>
    <div class="flex justify-center items-center space-x-2 mt-16">
      
      <% if (currentPage > 1) { %>
        <a href="/?page=<%= currentPage - 1 %>#all-products" class="px-4 py-2 bg-white border border-gray-300 rounded-lg text-gray-700 hover:bg-emerald-500 hover:text-white transition shadow-sm">
          Previous
