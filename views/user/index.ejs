        <a href="/?page=<%= i %>#all-products" 
           class="px-4 py-2 rounded-lg border transition font-medium <%= currentPage === i ? 'bg-emerald-600 text-white border-emerald-600 shadow-md' : 'bg-white border-gray-300 text-gray-700 hover:bg-emerald-500 hover:text-white' %>">
