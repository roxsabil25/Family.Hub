<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Family Hub</title>

<!-- Tailwind -->
<script src="https://cdn.tailwindcss.com"></script>

<!-- FontAwesome -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
.fade-up{
  animation: fadeUp .8s ease forwards;
}
@keyframes fadeUp{
  from{opacity:0; transform:translateY(40px);}
  to{opacity:1; transform:translateY(0);}
}
</style>

</head>

<body class="bg-gray-50 text-gray-800">

<!-- ================= NAVBAR ================= -->
<nav class="bg-white/90 backdrop-blur shadow fixed w-full z-50">
<div class="max-w-7xl mx-auto px-4">

<div class="flex justify-between items-center h-16">

<h2 class="text-2xl font-bold text-green-600">Family Hub</h2>

<!-- Desktop Menu -->
<ul class="hidden md:flex gap-8 font-medium items-center">

<li><a href="/" class="hover:text-green-600 transition">Home</a></li>

<li><a href="#" class="hover:text-green-600 transition">Products</a></li>

<!-- ✅ BULK PRODUCT DROPDOWN -->
<li class="relative group">

<button class="flex items-center gap-1 hover:text-green-600 transition">
Bulk Product
<i class="fa-solid fa-chevron-down text-xs"></i>
</button>

<ul class="absolute left-0 top-full mt-2 w-44
bg-white rounded-xl shadow-lg
opacity-0 invisible
group-hover:opacity-100
group-hover:visible
translate-y-2 group-hover:translate-y-0
transition-all duration-300 z-50">

<li>
<a href="/products/oil"
class="block px-4 py-2 hover:bg-gray-100 rounded-t-xl">
Oil
</a>
</li>

<li>
<a href="/products/dal"
class="block px-4 py-2 hover:bg-gray-100">
Dal
</a>
</li>

<li>
<a href="/products/fruits"
class="block px-4 py-2 hover:bg-gray-100 rounded-b-xl">
Fruits
</a>
</li>

</ul>
</li>

<li><a href="#" class="hover:text-green-600 transition">About</a></li>
<li><a href="#" class="hover:text-green-600 transition">Contact</a></li>

</ul>

<!-- Right Icons -->
<div class="hidden md:flex items-center gap-6">

<button class="flex items-center gap-2 hover:text-green-600 transition">
<i class="fa-solid fa-circle-user text-xl"></i>
<span>Account</span>
</button>

<button class="flex items-center gap-2 hover:text-green-600 transition">
<i class="fa-solid fa-headset"></i>
<span>Support</span>
</button>

<a href="/logout"
class="flex items-center gap-2 text-red-500 hover:text-red-600 font-medium">
<i class="fa-solid fa-right-from-bracket"></i>
Logout
</a>

</div>

<!-- Mobile Button -->
<button id="menuBtn" class="md:hidden text-2xl">
<i class="fa-solid fa-bars"></i>
</button>

</div>
</div>

<!-- ================= MOBILE MENU ================= -->
<div id="mobileMenu"
class="hidden md:hidden bg-white shadow-lg border-t">

<ul class="flex flex-col gap-4 p-5 font-medium">

<li><a href="/">Home</a></li>
<li><a href="#">Products</a></li>

<!-- Mobile dropdown simple -->
<li class="font-semibold text-gray-600">Bulk Product</li>
<li class="pl-4"><a href="/products/oil">Oil</a></li>
<li class="pl-4"><a href="/products/dal">Dal</a></li>
<li class="pl-4"><a href="/products/fruits">Fruits</a></li>

<li><a href="#">About</a></li>
<li><a href="#">Contact</a></li>

<li class="text-red-500"><a href="/logout">Logout</a></li>

</ul>

</div>
</nav>

<!-- ================= PRODUCT DETAILS ================= -->
<section class="pt-24 pb-14">
<div class="max-w-7xl mx-auto px-4">

<div class="grid md:grid-cols-2 gap-10 items-center">

<!-- PRODUCT IMAGE -->
<div class="bg-white rounded-2xl shadow-lg p-6">
<img src="<%= product.productsImge %>"
class="w-full h-[420px] object-cover rounded-xl">
</div>

<!-- PRODUCT INFO -->
<div>

<h1 class="text-4xl font-bold mb-4">
<%= product.productname %>
</h1>

<p class="text-gray-600 leading-relaxed mb-6">
<%= product.description %>
</p>

<div class="flex gap-4">

<a href="#"
class="bg-green-600 text-white px-8 py-3 rounded-xl
hover:bg-green-700 transition shadow-lg">
<i class="fa-solid fa-cart-shopping mr-2"></i>
Order Now
</a>

<a href="/"
class="border border-gray-300 px-8 py-3 rounded-xl
hover:bg-gray-100 transition">
Back
</a>

</div>

</div>

</div>

</div>
</section>

<!-- ================= EXTRA PRODUCT IMAGES ================= -->
<section class="py-14 bg-white">
<div class="max-w-7xl mx-auto px-4">

<h2 class="text-3xl font-bold text-center mb-12 tracking-wide">
MORE CATEGORIES
</h2>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">

<!-- CARD -->
 <% product.galleryImages.forEach(function(img){ %>
<div class="bg-gray-50 rounded-2xl overflow-hidden shadow
hover:shadow-2xl transition duration-300
hover:-translate-y-2 group cursor-pointer">

<div class="overflow-hidden">
    
<img src="<%= img %>"
class="h-32 w-full object-cover
group-hover:scale-110 transition duration-500">

</div>


</div>
<% }); %>



</div>
</div>
</section>

<!-- ================= RELATED PRODUCTS ================= -->
<section class="bg-white py-14">
<div class="max-w-7xl mx-auto px-4">

<h2 class="text-3xl font-bold text-center mb-10">
Related Products
</h2>

<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">

<% relatedProducts.forEach((item)=>{ %>

<a href="/products/details/<%= item._id %>"
class="bg-white rounded-2xl shadow hover:shadow-2xl
transition hover:-translate-y-2 group">

<div class="overflow-hidden">
<img src="<%= item.productsImge %>"
class="h-44 w-full object-cover
group-hover:scale-110 transition duration-500">
</div>

<h3 class="text-center py-4 font-semibold">
<%= item.productname %>
</h3>

</a>

<% }) %>

</div>

</div>
</section>

<!-- ================= FOOTER (SAME AS HOME) ================= -->

<!-- ================= FOOTER ================= -->
<footer class="bg-gray-900 text-gray-300 py-14">
<div class="max-w-7xl mx-auto px-4 text-center">

<h2 class="text-3xl text-white font-bold mb-10">
CONTACT US
</h2>

<div class="grid md:grid-cols-3 gap-10">

<div class="hover:text-green-400 transition">
<i class="fa-solid fa-location-dot text-2xl mb-3"></i>
<p>123 Main Street, City</p>
</div>

<div class="hover:text-green-400 transition">
<i class="fa-solid fa-phone text-2xl mb-3"></i>
<p>+1 234 567 890</p>
</div>

<div class="hover:text-green-400 transition">
<i class="fa-solid fa-envelope text-2xl mb-3"></i>
<p>contact@familyhub.com</p>
</div>

</div>
</div>
</footer>

<script>
const btn = document.getElementById("menuBtn");
const menu = document.getElementById("mobileMenu");

btn.addEventListener("click", ()=>{
  menu.classList.toggle("hidden");
});
</script>

</body>
</html>